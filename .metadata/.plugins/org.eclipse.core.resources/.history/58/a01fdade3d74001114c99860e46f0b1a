package com.tpfinal.batallanaval.UI;

import com.tpfinal.batallanaval.controller.PlayerController;
import com.tpfinal.batallanaval.game.GameListener;
import com.tpfinal.batallanaval.model.*;
import javax.swing.SwingUtilities;
import java.util.List;

public class GameUIAdapter implements GameListener {
    private final SwingUI vistaGrafica;
    private final PlayerController controller;
    private final GameConfig config;
    private final Boolean fixedPerspectiveP1;

    public GameUIAdapter(PlayerController controller, GameConfig config, Boolean fixedPerspectiveP1, SwingUI vistaGrafica) {
        this.vistaGrafica = vistaGrafica;
        this.controller = controller;
        this.config = config;
        this.fixedPerspectiveP1 = fixedPerspectiveP1;

        // Escuchamos el evento del click sobre el radar e impactamos el controlador de disparo
        this.vistaGrafica.setOnCasilleroRadarClicked((x, y) -> {
            this.controller.fireShot(x, y);
        });
    }

    @Override
    public void onGameStateChanged(GameSnapshot snapshot) {
        SwingUtilities.invokeLater(() -> {
            vistaGrafica.actualizarMensajeEstado("ESTADO: " + snapshot.state);

            boolean viewAsP1 = (fixedPerspectiveP1 != null) ? fixedPerspectiveP1 : 
                (snapshot.state == GameState.PLACING_SHIPS ? (snapshot.player1Ships.size() < config.getShipCount()) : snapshot.isPlayer1Turn);

            // Elegimos los datos correctos según la perspectiva dinámica u orientada
            List<Ship> misBarcos = viewAsP1 ? snapshot.player1Ships : snapshot.player2Ships;
            List<Position> misAgua = viewAsP1 ? snapshot.player1MissedShots : snapshot.player2MissedShots;
            
            List<Ship> barcosEnemigos = viewAsP1 ? snapshot.player2Ships : snapshot.player1Ships;
            List<Position> radarAgua = viewAsP1 ? snapshot.player2MissedShots : snapshot.player1MissedShots;

            // Renderizar Mapa "Mi Flota"
            renderizarMatrizTablero(misBarcos, misAgua, true);

            // Renderizar Mapa "Radar Enemigo"
            renderizarMatrizTablero(barcosEnemigos, radarAgua, false);
            
            // Si estamos en colocación, podemos usar clicks provisorios o avisar en cabecera
            if (snapshot.state == GameState.PLACING_SHIPS) {
                vistaGrafica.actualizarHistorial("Colocación: Turno de " + (viewAsP1 ? "Jugador 1" : "Jugador 2"));
            }
        });
    }

    private void renderizarMatrizTablero(List<Ship> ships, List<Position> misses, boolean esMiFlota) {
        for (int y = 0; y < config.getHeight(); y++) {
            for (int x = 0; x < config.getWidth(); x++) {
                Position currentPos = new Position(x, y);
                StatusCell estado = StatusCell.VACIO;

                if (misses.contains(currentPos)) {
                    estado = StatusCell.AGUA;
                }

                for (Ship ship : ships) {
                    for (Cell part : ship.getParts()) {
                        if (part.getPosition().equals(currentPos)) {
                            if (part.isHit()) {
                                estado = StatusCell.IMPACTO;
                            } else if (esMiFlota) {
                                // Solo mostramos los barcos intactos si es NUESTRO mapa de defensa
                                estado = StatusCell.BARCO;
                            }
                        }
                    }
                }

                if (esMiFlota) {
                    vistaGrafica.actualizarCasilleroMiFlota(x, y, estado);
                } else {
                    vistaGrafica.actualizarCasilleroRadar(x, y, estado);
                }
            }
        }
    }

    @Override
    public void onShipPlaced(Ship ship, int remainingCount) {
        SwingUtilities.invokeLater(() -> 
            vistaGrafica.actualizarHistorial("✅ ¡Barco colocado! Faltan colocar: " + remainingCount)
        );
    }

    @Override
    public void onError(String errorMessage) {
        SwingUtilities.invokeLater(() -> 
            vistaGrafica.actualizarHistorial("❌ Error: " + errorMessage)
        );
    }

    @Override
    public void onShotFired(Position pos, ShotResult result, boolean wasPlayer1) {
        SwingUtilities.invokeLater(() -> {
            String tirador = wasPlayer1 ? "Jugador 1" : "Enemigo";
            String strResult = switch (result) {
                case MISS -> "💦 ¡AGUA!";
                case HIT -> "🔥 ¡IMPACTO!";
                case SUNK -> "💥 ¡TOCADO Y HUNDIDO!";
            };
            vistaGrafica.actualizarHistorial(">>> " + tirador + " disparó a (" + pos.getX() + "," + pos.getY() + ") -> " + strResult);
        });
    }
}