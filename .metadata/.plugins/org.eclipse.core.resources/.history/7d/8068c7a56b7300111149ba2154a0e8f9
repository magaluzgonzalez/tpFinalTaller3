package com.tpfinal.batallanaval.UI;

import com.tpfinal.batallanaval.controller.PlayerController;
import com.tpfinal.batallanaval.model.*;
import java.util.List;

public class GameUIAdapter implements GameListener {
    private final PlayerController controller;
    private final GameConfig config;
    private final Boolean fixedPerspectiveP1;
    private final SwingUI vistaGrafica; // La UI tonta
    private GameSnapshot currentSnapshot;

    public GameUIAdapter(PlayerController controller, GameConfig config, Boolean fixedPerspectiveP1, SwingUI vistaGrafica) {
        this.controller = controller;
        this.config = config;
        this.fixedPerspectiveP1 = fixedPerspectiveP1;
        this.vistaGrafica = vistaGrafica;

        // Vinculamos el comportamiento de la barra de texto con nuestro procesador
        this.vistaGrafica.setOnCommandSubmitted(this::procesarComando);
    }

    @Override
    public void onGameStateChanged(GameSnapshot snapshot) {
        this.currentSnapshot = snapshot;
        vistaGrafica.limpiarPantalla(); 

        vistaGrafica.printLine("=========================================");
        vistaGrafica.printLine("ESTADO: " + snapshot.state);
        
        int w = config.getWidth();
        int h = config.getHeight();

        boolean viewAsP1 = (fixedPerspectiveP1 != null) ? fixedPerspectiveP1 : 
            (snapshot.state == GameState.PLACING_SHIPS ? (snapshot.player1Ships.size() < config.getShipCount()) : snapshot.isPlayer1Turn);

        if (snapshot.state == GameState.PLACING_SHIPS) {
            vistaGrafica.printLine("--- TURNO DE COLOCACIÓN: " + (viewAsP1 ? "JUGADOR 1" : "JUGADOR 2") + " ---");
            drawBoard(viewAsP1 ? snapshot.player1Ships : snapshot.player2Ships, 
                      viewAsP1 ? snapshot.player1MissedShots : snapshot.player2MissedShots, w, h, true);
            vistaGrafica.printLine("\n> Escribe: X Y Direccion(H/V) -> ej: '2 3 H'");
        }
        else if (snapshot.state == GameState.PLAYING) {
            vistaGrafica.printLine("TURNO DE: " + (snapshot.isPlayer1Turn ? "Jugador 1" : "Jugador 2"));
            
            vistaGrafica.printLine("\n--- MI FLOTA ---");
            drawBoard(viewAsP1 ? snapshot.player1Ships : snapshot.player2Ships, 
                      viewAsP1 ? snapshot.player1MissedShots : snapshot.player2MissedShots, w, h, true);
            
            vistaGrafica.printLine("\n--- RADAR ENEMIGO ---");
            drawBoard(viewAsP1 ? snapshot.player2Ships : snapshot.player1Ships, 
                      viewAsP1 ? snapshot.player2MissedShots : snapshot.player1MissedShots, w, h, false);
            
            if ((fixedPerspectiveP1 == null) || (snapshot.isPlayer1Turn == fixedPerspectiveP1)) {
                vistaGrafica.printLine("\n> ¡Es tu turno! Escribe coordenadas para disparar:");
            } else {
                vistaGrafica.printLine("\n> Esperando que el enemigo dispare...");
            }
        } 
        else if (snapshot.state == GameState.FINISHED) {
            vistaGrafica.printLine("¡PARTIDA TERMINADA! Ganador: " + (snapshot.isPlayer1Turn ? "Jugador 1" : "Jugador 2"));
        }
    }

    @Override
    public void onShipPlaced(Ship ship, int remainingCount) {
        vistaGrafica.printLine("✅ ¡Barco colocado! Faltan colocar: " + remainingCount);
    }

    @Override
    public void onError(String errorMessage) {
        vistaGrafica.printLine("❌ Error: " + errorMessage);
    }

    @Override
    public void onShotFired(Position pos, ShotResult result, boolean wasPlayer1) {
        String tirador = wasPlayer1 ? "Jugador 1" : "Bot/Enemigo";
        String strResult = switch (result) {
            case MISS -> "💦 ¡AGUA!";
            case HIT -> "🔥 ¡IMPACTO!";
            case SUNK -> "💥 ¡TOCADO Y HUNDIDO!";
        };
        vistaGrafica.printLine(">>> " + tirador + " dispara en (" + pos.getX() + "," + pos.getY() + ") -> " + strResult);
    }

    private void drawBoard(List<Ship> ships, List<Position> misses, int width, int height, boolean showIntactShips) {
        StringBuilder sb = new StringBuilder("  ");
        for (int x = 0; x < width; x++) sb.append(x).append(" ");
        sb.append("\n");

        for (int y = 0; y < height; y++) {
            sb.append(y).append(" ");
            for (int x = 0; x < width; x++) {
                Position currentPos = new Position(x, y);
                String symbol = "~ ";
                if (misses.contains(currentPos)) symbol = "O ";
                for (Ship ship : ships) {
                    for (Cell part : ship.getParts()) {
                        if (part.getPosition().equals(currentPos)) {
                            symbol = part.isHit() ? "X " : (showIntactShips ? "S " : "~ ");
                        }
                    }
                }
                sb.append(symbol);
            }
            sb.append("\n");
        }
        vistaGrafica.printLine(sb.toString());
    }

    // --- PROCESAMIENTO ÚNICO DE ENTRADAS ---
    private void procesarComando(String input) {
        if (input.equalsIgnoreCase("salir")) {
            vistaGrafica.dispose();
            return;
        }

        boolean isMyTurn = (fixedPerspectiveP1 == null) || (currentSnapshot.isPlayer1Turn == fixedPerspectiveP1);
        if (currentSnapshot.state == GameState.PLAYING && !isMyTurn) {
            vistaGrafica.printLine("Tranquilo, es el turno del enemigo...");
            return;
        }

        try {
            String[] parts = input.split(" ");
            int x = Integer.parseInt(parts[0]);
            int y = Integer.parseInt(parts[1]);

            if (currentSnapshot.state == GameState.PLACING_SHIPS) {
                Direction dir = parts[2].toUpperCase().startsWith("H") ? Direction.HORIZONTAL : Direction.VERTICAL;
                controller.attemptPlaceShip(x, y, dir);
            } else if (currentSnapshot.state == GameState.PLAYING) {
                controller.fireShot(x, y);
            }
        } catch (Exception e) {
            vistaGrafica.printLine("❌ Formato inválido.");
        }
    }
}