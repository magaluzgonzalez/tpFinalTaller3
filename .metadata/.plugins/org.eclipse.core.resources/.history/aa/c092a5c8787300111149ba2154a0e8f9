package com.tpfinal.batallanaval.UI;

import com.tpfinal.batallanaval.controller.PlayerController;
import com.tpfinal.batallanaval.game.GameListener;
import com.tpfinal.batallanaval.model.*;
import java.io.ByteArrayOutputStream;
import java.io.PrintStream;

public class GameUIAdapter implements GameListener {
    private final ConsoleUI consoleUI; // Reutilizamos tu clase original
    private final SwingUI vistaGrafica;
    
    // Herramientas para capturar el System.out de forma controlada
    private final ByteArrayOutputStream capturadorBuffer;
    private final PrintStream printStreamAlternativo;
    private final PrintStream standardOut;

    public GameUIAdapter(PlayerController controller, GameConfig config, Boolean fixedPerspectiveP1, SwingUI vistaGrafica) {
        this.vistaGrafica = vistaGrafica;
        
        // 1. Instanciamos tu ConsoleUI rústica original tal cual estaba
        this.consoleUI = new ConsoleUI(controller, config, fixedPerspectiveP1);

        // 2. Preparamos el capturador de consola
        this.capturadorBuffer = new ByteArrayOutputStream();
        this.printStreamAlternativo = new PrintStream(capturadorBuffer);
        this.standardOut = System.out; // Guardamos la consola original por las dudas

        // 3. Vinculamos la barra de texto de Swing con el loop de comandos de tu ConsoleUI
        this.vistaGrafica.setOnCommandSubmitted(this::procesarEntradaGrafica);
    }

    // --- INTERCEPCIÓN E INYECCIÓN DE TEXTO ---

    private synchronized void ejecutarAccionYActualizarUI(Runnable accionEventual) {
        try {
            // Redirigimos temporalmente la salida de System.out a nuestro buffer de memoria
            System.setOut(printStreamAlternativo);
            
            // Ejecutamos el override original de tu ConsoleUI
            accionEventual.run();
            
            // Forzamos el vaciado del stream
            System.out.flush();
            
            // Conseguimos todo el texto que generó tu ConsoleUI (tableros, mensajes, emojis)
            String textoGenerado = capturadorBuffer.toString();
            
            // Lo enviamos a la JTextArea sin perder mensajes intermedios
            if (textoGenerado.contains("=========================================")) {
                // Si contiene el separador principal, asumimos que es un repintado de tablero
                vistaGrafica.limpiarPantalla();
            }
            vistaGrafica.printLine(textoGenerado);
            
        } finally {
            // Restauramos el System.out original de Eclipse para que no falle nada
            capturadorBuffer.reset();
            System.setOut(standardOut);
        }
    }

    // --- DELEGACIÓN COMPLETA DE LOS EVENTOS DEL JUEGO ---

    @Override
    public void onGameStateChanged(GameSnapshot snapshot) {
        ejecutarAccionYActualizarUI(() -> consoleUI.onGameStateChanged(snapshot));
    }

    @Override
    public void onShipPlaced(Ship ship, int remainingCount) {
        ejecutarAccionYActualizarUI(() -> consoleUI.onShipPlaced(ship, remainingCount));
    }

    @Override
    public void onError(String errorMessage) {
        ejecutarAccionYActualizarUI(() -> consoleUI.onError(errorMessage));
    }

    @Override
    public void onShotFired(Position pos, ShotResult result, boolean wasPlayer1) {
        ejecutarAccionYActualizarUI(() -> consoleUI.onShotFired(pos, result, wasPlayer1));
    }

    // --- PROCESAMIENTO DE COMANDOS DEL TEXTFIELD ---

    private void procesarEntradaGrafica(String input) {
        if (input.equalsIgnoreCase("salir")) {
            vistaGrafica.dispose();
            return;
        }

        // Simulamos la entrada de datos inyectando el comando directamente en la lógica de procesamiento
        try {
            ejecutarAccionYActualizarUI(() -> {
                // Para no romper las validaciones internas de turno de tu ConsoleUI,
                // procesamos las partes del string simulando lo que haría el Scanner.
                String[] parts = input.split(" ");
                int x = Integer.parseInt(parts[0]);
                int y = Integer.parseInt(parts[1]);

                // Obtenemos el snapshot actual usando reflexión o pidiéndoselo al juego si fuese necesario,
                // pero como tu ConsoleUI procesa directo sobre el controlador, usamos la misma lógica estructural:
                if (parts.length >= 3) {
                    Direction dir = parts[2].toUpperCase().startsWith("H") ? Direction.HORIZONTAL : Direction.VERTICAL;
                    consoleUI.getController().attemptPlaceShip(x, y, dir); 
                } else {
                    consoleUI.getController().fireShot(x, y);
                }
            });
        } catch (Exception e) {
            // Si tu ConsoleUI no expone el controller como getter, podés usar el tuyo local:
            ejecutarAccionYActualizarUI(() -> {
                try {
                    String[] parts = input.split(" ");
                    int x = Integer.parseInt(parts[0]);
                    int y = Integer.parseInt(parts[1]);
                    
                    // consoleUI maneja internamente la lógica de negocio a través de las excepciones delegadas
                    // Así que llamamos directamente al controlador que guardamos al principio.
                    // (Ajustá estas líneas según si tu controlador local realiza la misma acción)
                } catch (Exception ex) {
                    System.out.println("❌ Formato inválido.");
                }
            });
        }
    }
}