package com.tpfinal.batallanaval.UI;

import javax.swing.*;
import javax.swing.border.EmptyBorder;
import java.awt.*;
import java.util.function.BiConsumer;

public class SwingUI extends JFrame {
    private static final long serialVersionUID = 1L;
    
    private final int columnas;
    private final int filas;

    private CasilleroBoton[][] panelMiFlota;
    private CasilleroBoton[][] panelRadar;
    
    private JLabel lblMensajeEstado;
    private JLabel lblHistorialAccion;
    
    // Callback para pasar las coordenadas (x, y) clickeadas al adaptador externo
    private BiConsumer<Integer, Integer> onCasilleroRadarClicked;

    public SwingUI(String titulo, int columnas, int filas) {
        setTitle(titulo);
        this.columnas = columnas;
        this.filas = filas;
        initUI();
    }

    private void initUI() {
        setSize(850, 500); // Ventana más ancha para contener ambos tableros lado a lado
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        setLocationRelativeTo(null);

        JPanel mainPanel = new JPanel(new BorderLayout(15, 15));
        mainPanel.setBorder(new EmptyBorder(15, 15, 15, 15));

        // --- Panel Superior de Mensajes (Sustituye logs secundarios) ---
        JPanel panelInformacion = new JPanel(new GridLayout(2, 1, 5, 5));
        panelInformacion.setBackground(new Color(45, 45, 45));
        panelInformacion.setBorder(new EmptyBorder(10, 10, 10, 10));
        
        lblMensajeEstado = new JLabel("=== INICIANDO PARTIDA ===", SwingConstants.CENTER);
        lblMensajeEstado.setForeground(Color.WHITE);
        lblMensajeEstado.setFont(new Font("SansSerif", Font.BOLD, 14));
        
        lblHistorialAccion = new JLabel("Esperando movimientos...", SwingConstants.CENTER);
        lblHistorialAccion.setForeground(Color.LIGHT_GRAY);
        lblHistorialAccion.setFont(new Font("SansSerif", Font.ITALIC, 12));
        
        panelInformacion.add(lblMensajeEstado);
        panelInformacion.add(lblHistorialAccion);
        mainPanel.add(panelInformacion, BorderLayout.NORTH);

        // --- Contenedor Central de Mapas ---
        JPanel panelTableros = new JPanel(new GridLayout(1, 2, 25, 0));
        
        // 1. Inicialización Tablero "Mi Flota"
        panelTableros.add(crearSeccionTablero("MI FLOTA (Defensa)", panelMiFlota = new CasilleroBoton[columnas][filas], false));
        
        // 2. Inicialización Tablero "Radar Enemigo"
        panelTableros.add(crearSeccionTablero("RADAR ENEMIGO (Ataque)", panelRadar = new CasilleroBoton[columnas][filas], true));

        mainPanel.add(panelTableros, BorderLayout.CENTER);
        add(mainPanel);
        setVisible(true);
    }

    private JPanel crearSeccionTablero(String titulo, CasilleroBoton[][] matriz, boolean esRadarInteractivo) {
        JPanel contenedor = new JPanel(new BorderLayout(5, 5));
        JLabel tituloTabla = new JLabel(titulo, SwingConstants.CENTER);
        tituloTabla.setFont(new Font("SansSerif", Font.BOLD, 12));
        contenedor.add(tituloTabla, BorderLayout.NORTH);

        // GridLayout simétrico usando las dimensiones del juego
        JPanel grid = new JPanel(new GridLayout(filas, columnas));
        for (int y = 0; y < filas; y++) {
            for (int x = 0; x < columnas; x++) {
                CasilleroBoton boton = new CasilleroBoton(x, y);
                matriz[x][y] = boton;
                
                if (esRadarInterinteractive) {
                    // Si es el radar de ataque, le habilitamos el click al botón
                    boton.addActionListener(e -> {
                        if (onCasilleroRadarClicked != null) {
                            onCasilleroRadarClicked.accept(boton.getXCoord(), boton.getYCoord());
                        }
                    });
                }
                grid.add(boton);
            }
        }
        contenedor.add(grid, BorderLayout.CENTER);
        return contenedor;
    }

    // --- MÉTODOS DE ACTUALIZACIÓN DESDE EL ADAPTER ---

    public void setOnCasilleroRadarClicked(BiConsumer<Integer, Integer> callback) {
        this.onCasilleroRadarClicked = callback;
    }

    public void actualizarMensajeEstado(String texto) {
        lblMensajeEstado.setText(texto);
    }

    public void actualizarHistorial(String texto) {
        lblHistorialAccion.setText(texto);
    }

    public void actualizarCasilleroMiFlota(int x, int y, CeldaEstado estado) {
        if (x >= 0 && x < columnas && y >= 0 && y < filas) {
            panelMiFlota[x][y].setEstado(estado);
        }
    }

    public void actualizarCasilleroRadar(int x, int y, CeldaEstado estado) {
        if (x >= 0 && x < columnas && y >= 0 && y < filas) {
            panelRadar[x][y].setEstado(estado);
        }
    }
}
