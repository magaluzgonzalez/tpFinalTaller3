package com.tpfinal.batallanaval.game;

import java.util.ArrayList;
import java.util.List;

import com.tpfinal.batallanaval.model.*;

public class Game {
    private final GameConfig config;
    private final Player player1;
    private final Player player2;
    
    private boolean isPlayer1Turn; 
    private GameState state; // <-- Reemplazamos el boolean isFinished por esto
    private final List<GameListener> listeners = new ArrayList<>();

    public Game(GameConfig config, String nameP1, String nameP2) {
        this.config = config;
        this.player1 = new Player(nameP1);
        this.player2 = new Player(nameP2);
        this.isPlayer1Turn = true;
        
        // ¡El juego siempre arranca en la fase de colocación!
        this.state = GameState.PLACING_SHIPS; 
    }
    
    public void addListener(GameListener listener) {
        this.listeners.add(listener);
    }
    
    /**
     * El megáfono: Genera el snapshot y avisa a todos.
     */
    public void notifyListeners() {
        GameSnapshot snapshot = new GameSnapshot(
            this.state,
            this.isPlayer1Turn,
            player1.getShips(),
            player1.getMissedShots(),
            player2.getShips(),
            player2.getMissedShots()
        );

        for (GameListener listener : listeners) {
            listener.onGameStateChanged(snapshot);
        }
    }
    
    private void notifyError(String msg) {
        for (GameListener l : listeners) l.onError(msg);
    }

    private void notifyShipPlaced(Ship ship, int remaining) {
        for (GameListener l : listeners) l.onShipPlaced(ship, remaining);
    }

    private void notifyShotFired(Position pos, ShotResult result, boolean p1Turn) {
        for (GameListener l : listeners) l.onShotFired(pos, result, p1Turn);
    }

    // --- FASE 1: COLOCACIÓN ---

    public boolean placeShip(Player player, Ship newShip) {
        if (this.state != GameState.PLACING_SHIPS) return false;

        // Validación 1
        for (Cell part : newShip.getParts()) {
            int x = part.getPosition().getX();
            int y = part.getPosition().getY();
            if (x < 0 || x >= config.getWidth() || y < 0 || y >= config.getHeight()) {
            	notifyError("El barco se sale de los límites del mapa.");
                return false; 
            }
        }

        // Validación 2
        for (Cell part : newShip.getParts()) {
            if (player.hasShipAt(part.getPosition())) {
            	notifyError("Ya hay un barco en esa posición.");
                return false; 
            }
        }

        // ¡Éxito!
        player.addShip(newShip);
        int remaining = config.getShipCount() - player.getShips().size();
        
        notifyShipPlaced(newShip, remaining); // <-- AVISAMOS DEL ÉXITO
        
        checkIfReadyToPlay();  
        notifyListeners(); // Actualizamos la pantalla
        return true;
    }

    /**
     * Revisa si ambos jugadores ya colocaron todos los barcos que exige la configuración.
     * Si es así, cambia el estado automáticamente a PLAYING.
     */
    private void checkIfReadyToPlay() {
        int requiredShips = config.getShipCount();
        
        if (player1.getShips().size() == requiredShips && 
            player2.getShips().size() == requiredShips) {
            
            this.state = GameState.PLAYING;
            notifyListeners();
        }
    }

    // --- FASE 2: DISPAROS ---

    // --- CÓMO SE USA EN TUS MÉTODOS ---
    
    public void processShot(Position targetPos) {
        if (this.state != GameState.PLAYING) return;

        int x = targetPos.getX();
        int y = targetPos.getY();
        if (x < 0 || x >= config.getWidth() || y < 0 || y >= config.getHeight()) {
        	notifyError("Disparo fuera del tablero. Intenta de nuevo.");
            return; 
        }

        Player defender = isPlayer1Turn ? player2 : player1;
        
        if (defender.hasAlreadyBeenShot(targetPos)) {
            notifyError("Ya disparaste a esa coordenada. Elige otra.");
            return;
        }
        
        // Obtenemos el resultado usando el nuevo Enum
        ShotResult result = defender.receiveShot(targetPos);
        
        // <-- AVISAMOS DEL RESULTADO DEL TIRO
        notifyShotFired(targetPos, result, isPlayer1Turn); 

        if (defender.hasLost()) {
            this.state = GameState.FINISHED;
        } else {
            if (result == ShotResult.MISS) {
                isPlayer1Turn = !isPlayer1Turn; // Cambia el turno solo si falla
            }
        }
        
        notifyListeners(); // Redibujamos la pantalla
    }
    
    public void forceState(GameState s) { this.state = s; }
 
    public GameState getState() { return state; }
    public GameConfig getConfig() { return config; }
	public Player getPlayer1() { return player1; }
	public Player getPlayer2() { return player2; }
	
	// para el erro de conexion de server/cliente
    public void onError(String errorMessage) {
        // Recorre todos los listeners que tiene el juego (entre ellos, tu GraphicUI)
        // y les grita el error en la jeta de forma automática
        for (GameListener listener : this.listeners) {
            listener.onError(errorMessage);
        }
}