package com.tpfinal.batallanaval.view;

import com.tpfinal.batallanaval.UI.PerspectiveManager;
import com.tpfinal.batallanaval.controller.PlayerController;
import com.tpfinal.batallanaval.game.GameListener;
import com.tpfinal.batallanaval.model.*;
import javax.swing.Timer;
import javax.swing.SwingUtilities;

public class GraphicUI implements GameListener {
    
    private final PlayerController controller; 
    private final GameConfig config;
    private final Boolean fixedPerspectiveP1;
    private final PerspectiveManager perspectiveManager;
    
    private final SwingUI vistaGrafica; 
    private final ConsoleUI consoleUI; // Nuestra central de texto
    private GameSnapshot ultimoSnapshot;
    private boolean bloqueadoPorTransicion = false;

 // --- Constructor Unificado ---
    public GraphicUI(PlayerController controller, GameConfig config, Boolean fixedPerspectiveP1) {
        this.controller = controller;
        this.config = config;
        this.fixedPerspectiveP1 = fixedPerspectiveP1;

        // 1. Primero creamos la ventana de Swing
        this.vistaGrafica = new SwingUI("Battleship - Control", config.getWidth(), config.getHeight(), this::mapearClickMouse);
        this.perspectiveManager = new PerspectiveManager(config, fixedPerspectiveP1);
        
        // 2. Le pasamos la vistaGrafica a ConsoleUI para que dibuje adentro de ella
        this.consoleUI = new ConsoleUI(controller, config, fixedPerspectiveP1, this.vistaGrafica);
    }

    private void mapearClickMouse(int x, int y, boolean esMiFlota, boolean esClicIzquierdo) {
        if (ultimoSnapshot == null || bloqueadoPorTransicion) return;

        // FASE 1: Colocación de barcos
        if (ultimoSnapshot.state == GameState.PLACING_SHIPS) {
            boolean leTocaColocarAP1 = (fixedPerspectiveP1 != null) ? fixedPerspectiveP1 : 
                (ultimoSnapshot.player1Ships.size() < config.getShipCount());

            if ((leTocaColocarAP1 && esMiFlota) || (!leTocaColocarAP1 && !esMiFlota)) {
                Direction dir = esClicIzquierdo ? Direction.HORIZONTAL : Direction.VERTICAL;
                
                // Llamamos directo al controlador, permitiendo que System.out funcione normal
                controller.attemptPlaceShip(x, y, dir);
                forzarRefrescoVisual();
            } else {
            	vistaGrafica.printLine("❌ No podés colocar barcos en el tablero del rival.");
            }
            return;
        }
        
        // FASE 2: Disparos
        if (ultimoSnapshot.state == GameState.PLAYING && esClicIzquierdo) {
            if (fixedPerspectiveP1 != null) {
                // --- MODO RED / IA ---
                boolean miTurnoRed = (fixedPerspectiveP1 && ultimoSnapshot.isPlayer1Turn) || (!fixedPerspectiveP1 && !ultimoSnapshot.isPlayer1Turn);
                boolean clickRadarRed = (fixedPerspectiveP1 && !esMiFlota) || (!fixedPerspectiveP1 && esMiFlota);

                if (miTurnoRed) {
                    if (clickRadarRed) {
                        controller.fireShot(x, y);
                        forzarRefrescoVisual();
                    } else {
                    	vistaGrafica.printLine("❌ ¡Disparo inválido! No podés dispararle a tu propia flota.");
                    }
                } else {
                	vistaGrafica.printLine("⚠️ Esperá, es el turno del enemigo remoto.");
                }
            } else {
            	// --- MODO HOTSEAT LOCAL (PVP) ---
                boolean clickValidoLocal = (ultimoSnapshot.isPlayer1Turn && !esMiFlota) || (!ultimoSnapshot.isPlayer1Turn && esMiFlota);

                if (clickValidoLocal) {
                    // Solo mandamos el tiro. El motor procesará si es HIT, MISS o SUNK
                    controller.fireShot(x, y);
                } else {
                    vistaGrafica.printLine("❌ ¡Disparo inválido! No podés dispararle a tu propia flota.");
                }
            }
        }
    }

    private void forzarRefrescoVisual() {
        if (ultimoSnapshot != null) {
            SwingUtilities.invokeLater(() -> perspectiveManager.aplicarPerspectiva(ultimoSnapshot, vistaGrafica));
        }
    }

    // =========================================================================
    // --- PASAMANOS DIRECTO A CONSOLE_UI ---
    // =========================================================================

    @Override
    public void onGameStateChanged(GameSnapshot snapshot) {
        this.ultimoSnapshot = snapshot;
        
        // Delegamos de una a la consola para que imprima el flujo actual
        this.consoleUI.onGameStateChanged(snapshot);

        if (!bloqueadoPorTransicion) {
            forzarRefrescoVisual();
        }
    }

    @Override
    public void onShipPlaced(Ship ship, int remainingCount) {
        this.consoleUI.onShipPlaced(ship, remainingCount);
    }

    @Override
    public void onShotFired(Position pos, ShotResult result, boolean isPlayer1Turn) {
        // Primero le pasamos el evento a la consola para que mantenga la bitácora al día
        this.consoleUI.onShotFired(pos, result, isPlayer1Turn);

        // Si el juego ya terminó con este tiro, no hacemos ninguna transición
        if (ultimoSnapshot != null && ultimoSnapshot.state == GameState.FINISHED) {
            return;
        }

        // Evaluamos el bardo del Hotseat Local (cuando fixedPerspectiveP1 es null)
        if (fixedPerspectiveP1 == null) {
            if (result == ShotResult.MISS) {
                // ¡AGUA! Toca cambiar de jugador obligatoriamente
                bloqueadoPorTransicion = true;
                
                vistaGrafica.printLine("\n=========================================");
                vistaGrafica.printLine("💦 ¡AGUA! CAMBIO DE TURNO...");
                vistaGrafica.printLine("Por favor, cedele la silla al siguiente jugador.");
                vistaGrafica.printLine("=========================================\n");

                Timer timer = new Timer(2000, e -> {
                    bloqueadoPorTransicion = false; // Desbloqueamos el mouse
                    forzarRefrescoVisual();         // Rota la pantalla mostrando el tablero del otro jugador
                });
                timer.setRepeats(false);
                timer.start();
            } else {
                // ¡HIT o SUNK! Le pegó a un barco.
                // No bloqueamos la transición, refrescamos visualmente para que vea el daño 
                // y como sigue siendo su turno, el modelo le permitirá disparar otra vez.
                vistaGrafica.printLine("🔥 ¡Buen tiro! Mantenés el turno. ¡Dispará de nuevo!");
                forzarRefrescoVisual();
            }
        }
    }

    @Override
    public void onError(String errorMessage) {
        this.consoleUI.onError(errorMessage);
    }
}