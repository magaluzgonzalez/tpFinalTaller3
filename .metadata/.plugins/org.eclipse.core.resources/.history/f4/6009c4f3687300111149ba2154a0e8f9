public class LocalPvPUI extends JFrame implements GameListener {
    private final PlayerController controller;
    private final GameConfig config;
    private final Boolean fixedPerspectiveP1;
    private GameSnapshot currentSnapshot;

    // Componentes visuales que actúan de terminal
    private JTextArea terminalOutput;
    private JTextField commandInput;

    public SwingUI(PlayerController controller, GameConfig config, Boolean fixedPerspectiveP1) {
        this.controller = controller;
        this.config = config;
        this.fixedPerspectiveP1 = fixedPerspectiveP1;

        // Inicializamos la ventana de testeo visual
        initUI();
    }

    private void initUI() {
        setTitle("Battleship - Consola Gráfica de Testeo");
        setSize(550, 650);
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        setLocationRelativeTo(null);

        // Panel Principal
        JPanel mainPanel = new JPanel(new BorderLayout(10, 10));
        mainPanel.setBorder(new EmptyBorder(15, 15, 15, 15));

        // Area de Texto para la salida de la terminal
        terminalOutput = new JTextArea();
        terminalOutput.setEditable(false);
        terminalOutput.setBackground(Color.BLACK);
        terminalOutput.setForeground(Color.GREEN); // Estilo consola clásica / Wine red si preferís
        terminalOutput.setFont(new Font("Monospaced", Font.PLAIN, 13)); // Monospaced es clave para que los tableros no se deformen
        
        JScrollPane scrollPane = new JScrollPane(terminalOutput);
        mainPanel.add(scrollPane, BorderLayout.CENTER);

        // Panel de entrada inferior (Label + TextField)
        JPanel inputPanel = new JPanel(new BorderLayout(5, 5));
        JLabel lblInput = new JLabel("Ingresar comando: ");
        commandInput = new JTextField();
        commandInput.setFont(new Font("Monospaced", Font.PLAIN, 13));
        
        // Listener cuando el usuario presiona ENTER en el TextField
        commandInput.addActionListener(this::procesarEntradaTeclado);

        inputPanel.add(lblInput, BorderLayout.WEST);
        inputPanel.add(commandInput, BorderLayout.CENTER);
        mainPanel.add(inputPanel, BorderLayout.SOUTH);

        add(mainPanel);
        setVisible(true);
        commandInput.requestFocusInWindow();
    }

    // --- MÉTODOS DE RECEPCIÓN (EVENTOS CORREGIDOS PARA IMPRIMIR EN PANTALLA) ---

    @Override
    public void onGameStateChanged(GameSnapshot snapshot) {
        this.currentSnapshot = snapshot;
        
        // Cada vez que cambia el estado, limpiamos el JTextArea para redibujar la pantalla
        terminalOutput.setText(""); 

        printLine("=========================================");
        printLine("ESTADO: " + snapshot.state);
        
        int w = config.getWidth();
        int h = config.getHeight();

        boolean viewAsP1;
        if (fixedPerspectiveP1 != null) {
            viewAsP1 = fixedPerspectiveP1;
        } else {
            if (snapshot.state == GameState.PLACING_SHIPS) {
                viewAsP1 = (snapshot.player1Ships.size() < config.getShipCount());
            } else {
                viewAsP1 = snapshot.isPlayer1Turn;
            }
        }

        if (snapshot.state == GameState.PLACING_SHIPS) {
            printLine("--- TURNO DE COLOCACIÓN: " + (viewAsP1 ? "JUGADOR 1" : "JUGADOR 2") + " ---");
            
            if (viewAsP1) {
                drawBoard(snapshot.player1Ships, snapshot.player1MissedShots, w, h, true);
            } else {
                drawBoard(snapshot.player2Ships, snapshot.player2MissedShots, w, h, true);
            }
            printLine("\n> Escribe: X Y Direccion(H/V) -> ej: '2 3 H'");
        }
        else if (snapshot.state == GameState.PLAYING) {
            printLine("TURNO DE: " + (snapshot.isPlayer1Turn ? "Jugador 1" : "Jugador 2"));
            
            printLine("\n--- MI FLOTA ---");
            if (viewAsP1) drawBoard(snapshot.player1Ships, snapshot.player1MissedShots, w, h, true);
            else drawBoard(snapshot.player2Ships, snapshot.player2MissedShots, w, h, true);
            
            printLine("\n--- RADAR ENEMIGO ---");
            if (viewAsP1) drawBoard(snapshot.player2Ships, snapshot.player2MissedShots, w, h, false);
            else drawBoard(snapshot.player1Ships, snapshot.player1MissedShots, w, h, false);
            
            boolean isMyTurn = (fixedPerspectiveP1 == null) || (snapshot.isPlayer1Turn == fixedPerspectiveP1);
            if (isMyTurn) {
                printLine("\n> ¡Es tu turno! Escribe coordenadas para disparar:");
            } else {
                printLine("\n> Esperando que el enemigo dispare...");
            }
        } 
        else if (snapshot.state == GameState.FINISHED) {
            printLine("¡PARTIDA TERMINADA! Ganador: " + (snapshot.isPlayer1Turn ? "Jugador 1" : "Jugador 2"));
        }
    }

    @Override
    public void onShipPlaced(Ship ship, int remainingCount) {
        printLine("✅ ¡Barco colocado! Faltan colocar: " + remainingCount);
    }

    @Override
    public void onError(String errorMessage) {
        printLine("❌ Error: " + errorMessage);
    }

    @Override
    public void onShotFired(Position pos, ShotResult result, boolean wasPlayer1) {
        String tirador = wasPlayer1 ? "Jugador 1" : "Bot Enemigo";
        StringBuilder shotLog = new StringBuilder();
        shotLog.append(">>> ").append(tirador).append(" dispara en (").append(pos.getX()).append(",").append(pos.getY()).append(") -> ");
        
        switch (result) {
            case MISS -> shotLog.append("💦 ¡AGUA!");
            case HIT -> shotLog.append("🔥 ¡IMPACTO!");
            case SUNK -> shotLog.append("💥 ¡TOCADO Y HUNDIDO!");
        }
        printLine(shotLog.toString());
    }

    // --- MÉTODOS AUXILIARES DE RENDERIZADO EN EL JTEXTAREA ---

    private void printLine(String text) {
        terminalOutput.append(text + "\n");
    }

    private void drawBoard(List<Ship> ships, List<Position> misses, int width, int height, boolean showIntactShips) {
        StringBuilder boardBuilder = new StringBuilder();
        boardBuilder.append("  ");
        for (int x = 0; x < width; x++) boardBuilder.append(x).append(" ");
        boardBuilder.append("\n");

        for (int y = 0; y < height; y++) {
            boardBuilder.append(y).append(" ");
            for (int x = 0; x < width; x++) {
                Position currentPos = new Position(x, y);
                String symbol = "~ ";

                if (misses.contains(currentPos)) symbol = "O ";

                for (Ship ship : ships) {
                    for (Cell part : ship.getParts()) {
                        if (part.getPosition().equals(currentPos)) {
                            if (part.isHit()) symbol = "X ";
                            else if (showIntactShips) symbol = "S ";
                        }
                    }
                }
                boardBuilder.append(symbol);
            }
            boardBuilder.append("\n");
        }
        printLine(boardBuilder.toString());
    }

    // --- PROCESAMIENTO DE COMANDOS (REEMPLAZO DEL LOOP WHILE + SCANNER) ---

    private void procesarEntradaTeclado(ActionEvent event) {
        String input = commandInput.getText().trim();
        commandInput.setText(""); // Limpiar la barra después de capturar el texto

        if (input.equalsIgnoreCase("salir")) {
            this.dispose();
            return;
        }

        boolean isMyTurn = (fixedPerspectiveP1 == null) || (currentSnapshot.isPlayer1Turn == fixedPerspectiveP1);
        if (currentSnapshot.state == GameState.PLAYING && !isMyTurn) {
            printLine("Tranquilo, es el turno del enemigo...");
            return;
        }

        try {
            String[] parts = input.split(" ");
            int x = Integer.parseInt(parts[0]);
            int y = Integer.parseInt(parts[1]);

            if (currentSnapshot.state == GameState.PLACING_SHIPS) {
                Direction dir = parts[2].toUpperCase().startsWith("H") ? Direction.HORIZONTAL : Direction.VERTICAL;
                controller.attemptPlaceShip(x, y, dir);
                
            } else if (currentSnapshot.state == GameState.PLAYING) {
                controller.fireShot(x, y);
            }
        } catch (Exception e) {
            printLine("❌ Formato inválido. Sigue las instrucciones de la pantalla.");
        }
    }
}
