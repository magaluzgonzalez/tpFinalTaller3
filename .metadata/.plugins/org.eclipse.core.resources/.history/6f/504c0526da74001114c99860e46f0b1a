package com.tpfinal.batallanaval.UI;

import com.tpfinal.batallanaval.model.*;
import java.util.List;

public class PerspectiveManager {
    private final GameConfig config;
    private final Boolean fixedPerspectiveP1;

    public PerspectiveManager(GameConfig config, Boolean fixedPerspectiveP1) {
        this.config = config;
        this.fixedPerspectiveP1 = fixedPerspectiveP1;
    }

    public void aplicarPerspectiva(GameSnapshot snapshot, SwingUI vista) {
        // 1. Determinar quién es el jugador que está mirando la pantalla en este milisegundo
        boolean viewAsP1;
        if (fixedPerspectiveP1 != null) {
            viewAsP1 = fixedPerspectiveP1; // IA o Red: Perspectiva fija
        } else {
            // Hotseat Local PvP: Dinámico
            if (snapshot.state == GameState.PLACING_SHIPS) {
                // Si al J1 le faltan barcos, ve su pantalla. Si terminó, pasa al J2.
                viewAsP1 = (snapshot.player1Ships.size() < config.getShipCount());
            } else {
                // Durante la partida, la pantalla se adapta al turno del jugador activo
                viewAsP1 = snapshot.isPlayer1Turn;
            }
        }

        // 2. Asignar las listas de datos correctas según el dueño de la perspectiva
        List<Ship> misBarcos = viewAsP1 ? snapshot.player1Ships : snapshot.player2Ships;
        List<Position> misAgua = viewAsP1 ? snapshot.player1MissedShots : snapshot.player2MissedShots;
        
        List<Ship> barcosEnemigos = viewAsP1 ? snapshot.player2Ships : snapshot.player1Ships;
        List<Position> radarAgua = viewAsP1 ? snapshot.player2MissedShots : snapshot.player1MissedShots;

        // 3. Modificar los títulos de la UI para que los jugadores sepan de quién es el turno
        String prefijoJugador = viewAsP1 ? "JUGADOR 1" : "JUGADOR 2";
        vista.actualizarTitulos(prefijoJugador + " - MI FLOTA", prefijoJugador + " - RADAR ENEMIGO");

        // 4. Dibujar las matrices usando la perspectiva calculada
        for (int y = 0; y < config.getHeight(); y++) {
            for (int x = 0; x < config.getWidth(); x++) {
                Position pos = new Position(x, y);
                
                // --- MAPEAR TABLERO IZQUIERDO (Mi Flota actual) ---
                StatusCell miEstado = misAgua.contains(pos) ? StatusCell.AGUA : StatusCell.VACIO;
                for (Ship s : misBarcos) {
                    for (Cell c : s.getParts()) {
                        if (c.getPosition().equals(pos)) {
                            miEstado = c.isHit() ? StatusCell.IMPACTO : StatusCell.BARCO; // Muestra barcos intactos (Amarillo)
                        }
                    }
                }
                vista.actualizarCasilleroMiFlota(x, y, miEstado);

                // --- MAPEAR TABLERO DERECHO (Radar de ataque actual) ---
                StatusCell radarEstado = radarAgua.contains(pos) ? StatusCell.AGUA : StatusCell.VACIO;
                for (Ship s : barcosEnemigos) {
                    for (Cell c : s.getParts()) {
                        if (c.getPosition().equals(pos) && c.isHit()) {
                            radarEstado = StatusCell.IMPACTO; // Solo muestra los aciertos (Rojo), oculta los intactos
                        }
                    }
                }
                vista.actualizarCasilleroRadar(x, y, radarEstado);
            }
        }
    }
}