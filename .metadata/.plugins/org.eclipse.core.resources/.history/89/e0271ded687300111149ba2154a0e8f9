package com.tpfinal.batallanaval.UI;

import javax.swing.JFrame;
import javax.swing.JPanel;
import javax.swing.JScrollPane;
import javax.swing.JTextArea;
import javax.swing.JTextField;
import java.awt.BorderLayout;
import java.awt.Font;
import java.io.IOException;
import java.io.OutputStream;
import java.io.PipedInputStream;
import java.io.PipedOutputStream;
import java.io.PrintStream;

public class LocalPvPUI {
    private final JFrame frame;
    private final JTextArea areaTextoConsola;
    private final JTextField campoEntrada;
    
    // Canales para redirigir el System.in de la consola rústica
    private PipedOutputStream pipeSalidaTeclado;
    private PipedInputStream pipeEntradaTeclado;

    public LocalPvPUI(String tituloVentana) {
        // 1. Configurar Ventana
        frame = new JFrame(tituloVentana);
        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        frame.setSize(700, 600); // Espacio cómodo para ver el tablero de Batalla Naval
        frame.setLocationRelativeTo(null);

        // 2. Área de Texto (La "Pantalla" de la terminal)
        areaTextoConsola = new JTextArea();
        areaTextoConsola.setEditable(false);
        // Usamos una fuente Monospaced (como la terminal) para que los tableros no se deformen
        areaTextoConsola.setFont(new Font("Monospaced", Font.PLAIN, 13)); 
        
        JScrollPane scrollPane = new JScrollPane(areaTextoConsola);

        // 3. Campo de Texto Inferior (La "Entrada" del Scanner)
        campoEntrada = new JTextField();
        campoEntrada.setFont(new Font("Monospaced", Font.PLAIN, 14));

        // 4. Armar el diseño
        JPanel panelPrincipal = new JPanel(new BorderLayout());
        panelPrincipal.add(scrollPane, BorderLayout.CENTER);
        panelPrincipal.add(campoEntrada, BorderLayout.SOUTH);
        frame.add(panelPrincipal);

        // 5. Configurar los flujos de E/S
        inicializarRedireccionDeFlujos();
    }

    public void mostrar() {
        frame.setVisible(true);
        campoEntrada.requestFocusInWindow(); // Hace foco en el input para poder escribir directo
    }

    private void inicializarRedireccionDeFlujos() {
        // --- REDIRECCIÓN DE SALIDA (System.out -> JTextArea) ---
        OutputStream uiOutputStream = new OutputStream() {
            @Override
            public void write(int b) throws IOException {
                // Cada carácter que el juego imprima se añade al JTextArea
                areaTextoConsola.append(String.valueOf((char) b));
                // Mueve el scroll automáticamente al final
                areaTextoConsola.setCaretPosition(areaTextoConsola.getDocument().getLength());
            }
        };
        // Cambiamos el System.out original por el nuestro customizado de la UI
        System.setOut(new PrintStream(uiOutputStream, true));

        // --- REDIRECCIÓN DE ENTRADA (JTextField -> System.in) ---
        try {
            pipeSalidaTeclado = new PipedOutputStream();
            pipeEntradaTeclado = new PipedInputStream(pipeSalidaTeclado);
            // El Scanner del juego ahora leerá lo que empujemos por este tubo
            System.setIn(pipeEntradaTeclado);
        } catch (IOException e) {
            e.printStackTrace();
        }

        // Evento cuando el usuario presiona ENTER en la caja de texto
        campoEntrada.addActionListener(e -> {
            String texto = campoEntrada.getText() + "\n"; // Añadimos el salto de línea que espera el Scanner
            campoEntrada.setText(""); // Limpiamos la barra de entrada
            
            // Escribimos en el hilo secundario del System.in simulado
            new Thread(() -> {
                try {
                    pipeSalidaTeclado.write(texto.getBytes());
                    pipeSalidaTeclado.flush();
                } catch (IOException ex) {
                    ex.printStackTrace();
                }
            }).start();
        });
    }
 }
