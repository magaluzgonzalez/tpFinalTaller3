package com.tpfinal.batallanaval.UI;

import javax.swing.*;
import java.awt.*;
import java.awt.event.MouseAdapter;
import java.awt.event.MouseEvent;
import java.util.function.BiConsumer;

public class BoardPanel extends JPanel {
    private static final long serialVersionUID = 1L;
    private final int columnas;
    private final int filas;
    private final CheckboxButton[][] matriz;

    public BoardPanel(int columnas, int filas, boolean esInteractivo, BiConsumer<CheckboxButton, Boolean> onButtonMouseClick) {
        this.columnas = columnas;
        this.filas = filas;
        this.matriz = new CheckboxButton[columnas][filas];

        // 🛠️ MODIFICADO: Le sumamos 1 a las filas y 1 a las columnas para el marco de números
        setLayout(new GridLayout(filas + 1, columnas + 1, 2, 2));
        setBackground(new Color(10, 25, 47)); // Fondo oscuro a tono con tu UI

        // =========================================================================
        // 1. FILA DE ARRIBA: Esquina vacía + Números de las Columnas (0 al 9)
        // =========================================================================
        add(new JLabel("")); // El casillero vacío de la esquina superior izquierda
        
        for (int x = 0; x < columnas; x++) {
            JLabel lblCol = new JLabel(String.valueOf(x), SwingConstants.CENTER);
            lblCol.setFont(new Font("SansSerif", Font.BOLD, 11));
            lblCol.setForeground(Color.LIGHT_GRAY);
            add(lblCol);
        }

        // =========================================================================
        // 2. CUERPO DEL TABLERO: Número de fila en la izquierda + Botones de la matriz
        // =========================================================================
        for (int y = 0; y < filas; y++) {
            
            // Ponemos el número de la fila actual antes de meter sus botones
            JLabel lblFila = new JLabel(String.valueOf(y), SwingConstants.CENTER);
            lblFila.setFont(new Font("SansSerif", Font.BOLD, 11));
            lblFila.setForeground(Color.LIGHT_GRAY);
            add(lblFila);

            for (int x = 0; x < columnas; x++) {
                CheckboxButton boton = new CheckboxButton(x, y);
                matriz[x][y] = boton;

                if (esInteractivo && onButtonMouseClick != null) {
                    boton.addMouseListener(new MouseAdapter() {
                        @Override
                        public void mousePressed(MouseEvent e) {
                            if (!boton.isEnabled()) return;
                            
                            boolean esClicIzquierdo = (e.getButton() == MouseEvent.BUTTON1);
                            onButtonMouseClick.accept(boton, esClicIzquierdo);
                        }
                    });
                }
                add(boton); // Se agrega el botón normalmente
            }
        }
    }

    public void actualizarCasillero(int x, int y, StatusCell status) {
        // Tu lógica de actualización sigue intacta porque la matriz interna no cambió de tamaño
        if (x >= 0 && x < columnas && y >= 0 && y < filas) {
            matriz[x][y].setEstado(status);
        }