package com.tpfinal.batallanaval.UI;

import com.tpfinal.batallanaval.controller.PlayerController;
import com.tpfinal.batallanaval.game.GameListener;
import com.tpfinal.batallanaval.model.*;
import com.tpfinal.batallanaval.view.ConsoleUI;

import java.io.ByteArrayOutputStream;
import java.io.PrintStream;
import java.util.LinkedList;
import java.util.Queue;
import java.util.List;
import javax.swing.SwingUtilities;

public class GameUIAdapter implements GameListener {
    private final ConsoleUI consoleUI; 
    private final SwingUI vistaGrafica;
    private final PlayerController controller;
    private final GameConfig config;
    private final Boolean fixedPerspectiveP1;
    
    private final Queue<String> historialAcciones = new LinkedList<>(); 
    private static final int MAX_MENSAJES_HISTORIAL = 5;

    private final ByteArrayOutputStream capturadorBuffer;
    private final PrintStream printStreamAlternativo;
    private final PrintStream standardOut;
    private void actualizarBotonesColores(GameSnapshot snapshot) {
        // Delegación limpia de la perspectiva
        perspectiveManager.aplicarPerspectiva(snapshot, vistaGrafica);
    }

    public GameUIAdapter(PlayerController controller, GameConfig config, Boolean fixedPerspectiveP1) {
        this.controller = controller;
        this.config = config;
        this.fixedPerspectiveP1 = fixedPerspectiveP1;

        // Pasamos las medidas al inicializar de manera transparente
        this.vistaGrafica = new SwingUI("Battleship - Gráfica Integrada", config.getWidth(), config.getHeight());
        this.consoleUI = new ConsoleUI(controller, config, fixedPerspectiveP1);

        this.capturadorBuffer = new ByteArrayOutputStream();
        this.printStreamAlternativo = new PrintStream(capturadorBuffer);
        this.standardOut = System.out;

        this.vistaGrafica.setOnCommandSubmitted(this::procesarEntradaGrafica);
        this.perspectiveManager = new PerspectiveManager(config, fixedPerspectiveP1);
    }

    private synchronized void ejecutarAccionYActualizarUI(Runnable accionEventual, GameSnapshot snapshotOpcional) {
        System.setOut(printStreamAlternativo);
        try {
            accionEventual.run();
            System.out.flush();
        } finally {
            System.setOut(standardOut);
        }

        String textoGenerado = capturadorBuffer.toString();
        capturadorBuffer.reset();

        SwingUtilities.invokeLater(() -> {
            if (textoGenerado.contains("=========================================")) {
                vistaGrafica.limpiarPantalla();
                vistaGrafica.printLine(textoGenerado);
                
                if (!historialAcciones.isEmpty()) {
                    vistaGrafica.printLine("\n--- ÚLTIMOS MOVIMIENTOS ---");
                    for (String msg : historialAcciones) vistaGrafica.printLine(msg);
                }

                // SI hay un snapshot fresco, refrescamos en paralelo los botones físicos de color
                if (snapshotOpcional != null) {
                    actualizarBotonesColores(snapshotOpcional);
                }
            } else if (!textoGenerado.trim().isEmpty()) {
                if (historialAcciones.size() >= MAX_MENSAJES_HISTORIAL) historialAcciones.poll();
                historialAcciones.add(textoGenerado.trim());
                vistaGrafica.printLine(textoGenerado.trim());
            }
        });
    }

    private void actualizarBotonesColores(GameSnapshot snapshot) {
        boolean viewAsP1 = (fixedPerspectiveP1 != null) ? fixedPerspectiveP1 : 
            (snapshot.state == GameState.PLACING_SHIPS ? (snapshot.player1Ships.size() < config.getShipCount()) : snapshot.isPlayer1Turn);

        List<Ship> misBarcos = viewAsP1 ? snapshot.player1Ships : snapshot.player2Ships;
        List<Position> misAgua = viewAsP1 ? snapshot.player1MissedShots : snapshot.player2MissedShots;
        
        List<Ship> barcosEnemigos = viewAsP1 ? snapshot.player2Ships : snapshot.player1Ships;
        List<Position> radarAgua = viewAsP1 ? snapshot.player2MissedShots : snapshot.player1MissedShots;

        for (int y = 0; y < config.getHeight(); y++) {
            for (int x = 0; x < config.getWidth(); x++) {
                Position pos = new Position(x, y);
                
                // Mapear Mi Flota
                StatusCell miEstado = misAgua.contains(pos) ? StatusCell.AGUA : StatusCell.VACIO;
                for (Ship s : misBarcos) {
                    for (Cell c : s.getParts()) {
                        if (c.getPosition().equals(pos)) miEstado = c.isHit() ? StatusCell.IMPACTO : StatusCell.BARCO;
                    }
                }
                vistaGrafica.actualizarCasilleroMiFlota(x, y, miEstado);

                // Mapear Radar
                StatusCell radarEstado = radarAgua.contains(pos) ? StatusCell.AGUA : StatusCell.VACIO;
                for (Ship s : barcosEnemigos) {
                    for (Cell c : s.getParts()) {
                        if (c.getPosition().equals(pos) && c.isHit()) radarEstado = StatusCell.IMPACTO;
                    }
                }
                vistaGrafica.actualizarCasilleroRadar(x, y, radarEstado);
            }
        }
    }

    @Override public void onGameStateChanged(GameSnapshot snapshot) { ejecutarAccionYActualizarUI(() -> consoleUI.onGameStateChanged(snapshot), snapshot); }
    @Override public void onShipPlaced(Ship ship, int remainingCount) { ejecutarAccionYActualizarUI(() -> consoleUI.onShipPlaced(ship, remainingCount), null); }
    @Override public void onError(String errorMessage) { ejecutarAccionYActualizarUI(() -> consoleUI.onError(errorMessage), null); }
    @Override public void onShotFired(Position pos, ShotResult result, boolean wasPlayer1) { ejecutarAccionYActualizarUI(() -> consoleUI.onShotFired(pos, result, wasPlayer1), null); }

    private void procesarEntradaGrafica(String input) {
        if (input.equalsIgnoreCase("salir")) { vistaGrafica.dispose(); return; }
        try {
            ejecutarAccionYActualizarUI(() -> {
                String[] parts = input.split(" ");
                int x = Integer.parseInt(parts[0]);
                int y = Integer.parseInt(parts[1]);
                if (parts.length >= 3) {
                    Direction dir = parts[2].toUpperCase().startsWith("H") ? Direction.HORIZONTAL : Direction.VERTICAL;
                    controller.attemptPlaceShip(x, y, dir); 
                } else {
                    controller.fireShot(x, y);
                }
            }, null);
        } catch (Exception e) {
            ejecutarAccionYActualizarUI(() -> System.out.println("❌ Formato inválido."), null);
        }
    }
}