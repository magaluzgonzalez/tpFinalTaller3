package com.tpfinal.batallanaval;

import com.tpfinal.batallanaval.controller.*;
import com.tpfinal.batallanaval.game.Game;
import com.tpfinal.batallanaval.model.GameConfig;
import com.tpfinal.batallanaval.network.NetworkClientController;
import com.tpfinal.batallanaval.network.NetworkServer;
import com.tpfinal.batallanaval.view.GraphicUI;
import com.tpfinal.batallanaval.view.MainMenuUI;

public class App {
    
    // 🔌 CONTROL: Guardamos el menú actual para que los métodos lo puedan levantar
    private static MainMenuUI menuActual;

    public static void main(String[] args) {
        javax.swing.SwingUtilities.invokeLater(() -> {
            createAndShowMenu();
        });
    }

    private static void createAndShowMenu() {
        // Inicializamos la variable estática con el nuevo menú
        menuActual = new MainMenuUI(
            App::startLocalPvPMode, 
            App::startLocalAIMode, 
            App::startModeHost,
            App::startClientMode
        );
        menuActual.show();
    }

    // --- MÉTODOS DE MODOS DE JUEGO OPTIMIZADOS ---

    private static void startLocalPvPMode() {
        GameConfig config = GameConfig.createDefault();
        Game game = new Game(config, "Jugador 1", "Jugador 2");
        PlayerController hotseatController = new HotseatController(game);
        
        // 🔌 ENGANCHE: Pasamos el menuActual al final
        GraphicUI graphicUI = new GraphicUI(hotseatController, config, null, menuActual);
        
        game.addListener(graphicUI);
        game.notifyListeners();
    } 

    private static void startLocalAIMode() {
        GameConfig config = GameConfig.createDefault();
        Game game = new Game(config, "Humano", "Bot");
        PlayerController p1Controller = new LocalController(game, true);
        AIController bot = new AIController(game, false);

        // 🔌 ENGANCHE: Pasamos el menuActual al final
        GraphicUI graphicUI = new GraphicUI(p1Controller, config, true, menuActual);

        game.addListener(graphicUI);
        game.addListener(bot);
        game.notifyListeners();
    }
 
    private static void startModeHost() {
        System.out.println("Iniciando Servidor Battleship...");
        GameConfig config = GameConfig.createDefault();
        Game game = new Game(config, "Host (Tú)", "Cliente (Remoto)");
        
        PlayerController localController = new LocalController(game, true);
        
        // 🔌 ENGANCHE: Pasamos el menuActual al final
        GraphicUI graphicUI = new GraphicUI(localController, config, true, menuActual);
        
        game.addListener(graphicUI);
        
        NetworkServer server = new NetworkServer(game, 8080);
        server.startListeningInBackground();
        
        game.notifyListeners(); 
    }

    private static void startClientMode() {
        System.out.println("Conectando al Servidor...");
        GameConfig config = GameConfig.createDefault(); 
        
        NetworkClientController netController = new NetworkClientController("127.0.0.1", 8080);
        
        // 🔌 ENGANCHE: Pasamos el menuActual al final
        GraphicUI graphicUI = new GraphicUI(netController, config, false, menuActual);
        
        netController.setUI(graphicUI);
    }
}
